function SendWebhook(message)
    local url = getgenv().WebhookUrl
    if url == "" then return end
    local data = {
        username = MarketplaceService:GetProductInfo(game.PlaceId).Name,
        embeds = {{ description = message, color = 255, timestamp = DateTime.now():ToIsoDate() }}
    }
    local body = HttpService:JSONEncode(data)
    local req = http_request or request or HttpPost or syn.request
    if req then
        req({ Url = url, Body = body, Method = "POST", Headers = { ["content-type"] = "application/json" } })
    end
end

