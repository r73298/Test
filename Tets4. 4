function AutoGrab()
    getgenv().AutoGrab = true
    while getgenv().AutoGrab do
        pcall(function()
            LocalPlayer.Character.Events.Grab:FireServer(false, false)
        end)
        task.wait(1.3)
    end
end

function AutoEat()
    getgenv().AutoEat = true
    while getgenv().AutoEat do
        pcall(function()
            LocalPlayer.Character.Events.Eat:FireServer()
        end)
        task.wait(0)
    end
end

function AutoTeleport()
    getgenv().AutoTeleport = true
    while getgenv().AutoTeleport do
        pcall(function()
            local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
            local primary = char.PrimaryPart
            if primary then primary.Anchored = true end
            local parts = {}
            for _, child in ipairs(Workspace:GetDescendants()) do
                if child:IsA("BasePart") then table.insert(parts, child) end
            end
            if #parts == 0 then warn("No BaseParts found") return end
            local target = parts[math.random(1, #parts)]
            char:SetPrimaryPartCFrame(CFrame.new(target.Position))
        end)
        task.wait(getgenv().TeleportDelay or 1.0)
    end
end

function UnanchorCharacter()
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local primary = char.PrimaryPart
    if primary then primary.Anchored = false end
end

function AutoSellByAmount()
    getgenv().AutoSellByAmount = true
    while getgenv().AutoSellByAmount do
        pcall(function()
            local leaderstats = LocalPlayer:FindFirstChild("leaderstats")
            if leaderstats then
                local blockStat = leaderstats:FindFirstChild("Size") or leaderstats:FindFirstChild("Blocks") or leaderstats:FindFirstChild("Brick") or leaderstats:FindFirstChild("Bricks") or leaderstats:FindFirstChild("Block")
                if blockStat and blockStat.Value >= (getgenv().SellAtAmount or 1000) then
                    LocalPlayer.Character.Events.Sell:FireServer()
                end
            end
        end)
        task.wait(0.5)
    end
end

function AutoSellBlocks()
    getgenv().AutoSellBlocks = true
    while getgenv().AutoSellBlocks do
        task.wait(getgenv().AutoSellSlider or 1)
        pcall(function()
            LocalPlayer.Character.Events.Sell:FireServer()
        end)
    end
end

-- FIXED: Wrapped gsub in parentheses to prevent double return value
function GetCubes()
    local gui = LocalPlayer:FindFirstChild("PlayerGui")
    if not gui then return 0 end
    local screenGui = gui:FindFirstChild("ScreenGui")
    if not screenGui then return 0 end
    local cubesFrame = screenGui:FindFirstChild("Cubes")
    if not cubesFrame then return 0 end
    local counterFrame = cubesFrame:FindFirstChild("CounterFrame")
    if not counterFrame then return 0 end
    local textLabel = counterFrame:FindFirstChild("TextLabel")
    if not textLabel then return 0 end
    local num = tonumber((textLabel.Text:gsub(",", "")))  -- FIXED: extra parentheses
    return num or 0
end

-- ============================================
-- FIXED: GetUpgradePrice using ItemInfo module
-- No more Shop UI dependency!
-- ============================================
local ItemInfo = require(ReplicatedStorage:WaitForChild("ItemInfo"))

function GetUpgradePrice(upgradeName)
    local upgradesFolder = LocalPlayer:FindFirstChild("Upgrades")
    if not upgradesFolder then return nil end
    
    local levelValue = upgradesFolder:FindFirstChild(upgradeName)
    if not levelValue then return nil end
    
    local currentLevel = levelValue.Value
    local upgradeData = ItemInfo.Upgrades[upgradeName]
    if not upgradeData then return nil end
    
    -- priceFunction takes the NEXT level (current + 1)
    local price = upgradeData.priceFunction(currentLevel + 1)
    return price
end

function StopAllAutoUpgrades()
    getgenv().AutoUpgradeMaxSize = false
    getgenv().AutoUpgradeSpeed = false
    getgenv().AutoUpgradeMultiplier = false
    getgenv().AutoUpgradeEatSpeed = false
end

function SendWebhook(message)
    if not getgenv().WebhookEnabled or getgenv().WebhookUrl == "" or getgenv().WebhookUrl == nil then
        return
    end
    
    local data = {
        content = message
    }
    
    local body = HttpService:JSONEncode(data)
    local req = http_request or request or HttpPost or syn.request
    
    if req then
        pcall(function()
            req({
                Url = getgenv().WebhookUrl,
                Body = body,
                Method = "POST",
                Headers = { ["content-type"] = "application/json" }
            })
        end)
    end
end

