function GetCubes()
    local player = game:GetService('Players').LocalPlayer
    local gui = player:FindFirstChild('PlayerGui')
    if not gui then return 0 end
    local screenGui = gui:FindFirstChild('ScreenGui')
    if not screenGui then return 0 end
    local cubesFrame = screenGui:FindFirstChild('Cubes')
    if not cubesFrame then return 0 end
    local counterFrame = cubesFrame:FindFirstChild('CounterFrame')
    if not counterFrame then return 0 end
    local textLabel = counterFrame:FindFirstChild('TextLabel')
    if not textLabel then return 0 end
    local text = textLabel.Text
    local numStr = text:gsub(',', '')
    local num = tonumber(numStr)
    return num or 0
end

function GetUpgradePrice(upgradeName)
    local player = game:GetService('Players').LocalPlayer
    local gui = player:FindFirstChild('PlayerGui')
    if not gui then return nil end
    local screenGui = gui:FindFirstChild('ScreenGui')
    if not screenGui then return nil end
    local shop = screenGui:FindFirstChild('Shop')
    if not shop then return nil end
    local shopFrames = shop:FindFirstChild('ShopFrames')
    if not shopFrames then return nil end
    local upgrades = shopFrames:FindFirstChild('Upgrades')
    if not upgrades then return nil end
    local upgradeList = upgrades:FindFirstChild('UpgradeList')
    if not upgradeList then return nil end
    local upgradeFrame = upgradeList:FindFirstChild(upgradeName)
    if not upgradeFrame then return nil end
    local buyFrame = upgradeFrame:FindFirstChild('BuyFrame')
    if not buyFrame then return nil end
    local priceFrame = buyFrame:FindFirstChild('Price')
    if not priceFrame then return nil end
    local text = priceFrame.Text
    local numStr = text:gsub(',', '')
    local num = tonumber(numStr)
    return num
end

