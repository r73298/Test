-- FIXED AUTO UPGRADE FUNCTIONS
-- Uses ItemInfo priceFunction + player Upgrades level
-- ============================================
function AutoUpgradeMaxSize()
    getgenv().AutoUpgradeMaxSize = true
    while getgenv().AutoUpgradeMaxSize do
        local cubes = GetCubes()
        local price = GetUpgradePrice("MaxSize")
        
        if price == nil then
            task.wait(0.5)
            continue
        end
        
        if cubes >= price then
            ReplicatedStorage.Events.PurchaseEvent:FireServer("MaxSize")
            task.wait(0.8) -- Wait for server to process + level to update
        else
            task.wait(0.3) -- Fast check when can't afford
        end
    end
end

